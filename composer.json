{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bambamboole/spectacular",
    "description": "OpenAPI and AsyncAPI tooling for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "openapi",
        "asyncapi",
        "scramble",
        "spatie-query-builder"
    ],
    "authors": [
        {
            "name": "Manuel Christlieb",
            "email": "manuel@christlieb.eu"
        }
    ],
    "require": {
        "php": "^8.4",
        "dedoc/scramble": "^0.13.30",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.16 || ^2.0",
        "spatie/laravel-query-builder": "^7.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.29",
        "lattice-php/lattice": "^0.15",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "suggest": {
        "lattice-php/lattice": "Render the generated OpenAPI/AsyncAPI documents as a UI with the Spectacular Lattice viewer (^0.15)."
    },
    "autoload": {
        "psr-4": {
            "Bambamboole\\Spectacular\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bambamboole\\Spectacular\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "analyse": "./vendor/bin/phpstan analyse",
        "check": [
            "@test:lint",
            "@analyse",
            "@test"
        ],
        "lint": "./vendor/bin/pint",
        "test:lint": "./vendor/bin/pint --test",
        "test": "./vendor/bin/pest",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "post-install-cmd": "@boost:refresh",
        "post-update-cmd": "@boost:refresh",
        "boost:refresh": "@php vendor/bin/testbench boost:update --no-interaction",
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php artisan serve --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bambamboole\\Spectacular\\SpectacularServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
