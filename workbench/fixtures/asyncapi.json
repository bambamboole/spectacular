{
    "asyncapi": "3.0.0",
    "info": {
        "title": "Workbench AsyncAPI",
        "version": "1.0.0"
    },
    "defaultContentType": "application/json",
    "channels": {
        "private-users.{userId}": {
            "address": "private-users.{userId}",
            "messages": {
                "Workbench.App.Events.UserNotificationReceived": {
                    "$ref": "#/components/messages/Workbench.App.Events.UserNotificationReceived"
                }
            },
            "x-laravel-channel-type": "private"
        },
        "webhooks": {
            "address": "{webhookUrl}",
            "messages": {
                "invoice.paid": {
                    "$ref": "#/components/messages/invoice.paid"
                }
            },
            "x-spectacular-channel-kind": "webhook"
        }
    },
    "operations": {
        "Workbench.App.Events.UserNotificationReceived.send": {
            "action": "send",
            "channel": {
                "$ref": "#/channels/private-users.{userId}"
            },
            "messages": [
                {
                    "$ref": "#/channels/private-users.{userId}/messages/Workbench.App.Events.UserNotificationReceived"
                }
            ]
        },
        "invoice.paid.send": {
            "action": "send",
            "channel": {
                "$ref": "#/channels/webhooks"
            },
            "messages": [
                {
                    "$ref": "#/channels/webhooks/messages/invoice.paid"
                }
            ]
        }
    },
    "components": {
        "messages": {
            "Workbench.App.Events.UserNotificationReceived": {
                "name": "user.notification.received",
                "summary": "User notification received",
                "description": "Sent when a user receives a notification in the workbench app.",
                "tags": [
                    {
                        "name": "notifications"
                    }
                ],
                "payload": {
                    "type": "object",
                    "properties": {
                        "userId": {
                            "type": "integer"
                        },
                        "team": {
                            "type": "string"
                        },
                        "unreadCount": {
                            "type": "integer"
                        }
                    },
                    "required": [
                        "userId",
                        "team",
                        "unreadCount"
                    ]
                },
                "x-laravel-event": "Workbench\\App\\Events\\UserNotificationReceived",
                "x-laravel-broadcast-now": false
            },
            "invoice.paid": {
                "name": "invoice.paid",
                "title": "Invoice Paid",
                "summary": "Sent when a workbench invoice is paid.",
                "tags": [
                    {
                        "name": "billing"
                    }
                ],
                "headers": {
                    "type": "object",
                    "properties": {
                        "Content-Type": {
                            "type": "string",
                            "enum": [
                                "application/json"
                            ]
                        },
                        "Signature": {
                            "type": "string"
                        },
                        "Timestamp": {
                            "type": "integer"
                        }
                    }
                },
                "payload": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "event": {
                            "type": "string",
                            "enum": [
                                "invoice.paid"
                            ]
                        },
                        "createdAt": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "data": {
                            "type": "object",
                            "properties": {
                                "invoiceId": {
                                    "type": "integer"
                                },
                                "amount": {
                                    "type": "integer"
                                }
                            },
                            "required": [
                                "invoiceId",
                                "amount"
                            ]
                        }
                    },
                    "required": [
                        "id",
                        "event",
                        "createdAt",
                        "data"
                    ]
                },
                "x-spectacular-webhook-event": "invoice.paid",
                "x-spectacular-source-class": "Workbench\\App\\Events\\InvoicePaid"
            }
        }
    }
}
